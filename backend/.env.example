# AutoFilm Backend — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

# Mux (video hosting) — mux.com/settings/access-tokens
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=

# Twilio (SMS) — console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# Supabase — supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://XXXX.supabase.co
SUPABASE_SERVICE_KEY=

# Anthropic (AI script generation proxy)
ANTHROPIC_API_KEY=

# Cloudflare (KV short links) — dash.cloudflare.com
CF_WORKER_URL=https://links.autofilm.io
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_KV_NAMESPACE_ID=

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:ken@harteautogroup.com

# SendGrid (email delivery) — sendgrid.com/app/settings/api_keys
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=videos@autofilm.io
SENDGRID_FROM_NAME=AutoFilm

# Text-to-Speech for VIN Reels (one or both)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=         # default: Rachel (21m00Tcm4TlvDq8ikWAM)
GOOGLE_TTS_API_KEY=

# HeyGen AI Avatar — heygen.com/api
HEYGEN_API_KEY=
# HEYGEN_VOICE_ID=             # optional: default uses avatar's cloned voice

# Twilio RCS (optional — enables rich messaging with cards + buttons)
TWILIO_RCS_SENDER_ID=

# YouTube Distribution (optional)
YOUTUBE_API_KEY=
YOUTUBE_OAUTH_TOKEN=

# Facebook Distribution (optional)
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_TOKEN=

# Stripe billing — dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=       # from the webhook endpoint config
STRIPE_PRICE_STANDARD=       # price id for $299/rooftop/mo
STRIPE_PRICE_BUNDLE=         # price id for $599/rooftop/mo suite
STRIPE_TRIAL_DAYS=30

# Mux webhook signature verification (optional but recommended)
MUX_WEBHOOK_SECRET=

# Vehicle stock imagery (auto-populates MPI vehicle photo from VIN / year-make-model)
MARKETCHECK_API_KEY=         # marketcheck.com listings API key
VEHICLE_IMAGE_PROVIDER=marketcheck   # marketcheck | evox | none
EVOX_API_KEY=                # only when VEHICLE_IMAGE_PROVIDER=evox

# AutoCurb bundled mode (optional — only for tenant JWT verification)
AUTOCURB_JWT_SECRET=

# Reminder delivery worker (vehicle_reminders → SMS follow-ups)
# Off by default — set to true only once migration 015 is applied and
# the rooftop is ready for customer-facing texts.
REMINDERS_ENABLED=false
# REMINDER_WORKER_INTERVAL_MS=3600000   # optional: tick interval, default hourly

# Lifetime pricing offers ("lifetime brakes" etc.) — platform kill switch.
# Rooftops cannot save mode=tier_plus_lifetime or lifetime_enabled=true
# unless this is true (pending legal review).
LIFETIME_OFFERS_ENABLED=false

# App URL (for magic links, email redirects)
APP_URL=https://autofilm.io

# Server
PORT=3001
NODE_ENV=development
