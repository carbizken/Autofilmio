{
  "version": 2,
  "builds": [
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/frontend/autofilm-landing.html"
    },
    {
      "src": "/app",
      "dest": "/frontend/autofilm-app.html"
    },
    {
      "src": "/player",
      "dest": "/frontend/autofilm-player.html"
    },
    {
      "src": "/command",
      "dest": "/frontend/autofilm-command.html"
    },
    {
      "src": "/admin",
      "dest": "/frontend/autofilm-admin.html"
    },
    {
      "src": "/pitch",
      "dest": "/frontend/autofilm-pitch.html"
    },
    {
      "src": "/trade",
      "dest": "/frontend/hartecash-trade.html"
    },
    {
      "src": "/login",
      "dest": "/frontend/autofilm-login.html"
    },
    {
      "src": "/sso",
      "dest": "/frontend/autofilm-sso.html"
    },
    {
      "src": "/settings",
      "dest": "/frontend/autofilm-settings.html"
    },
    {
      "src": "/record",
      "dest": "/frontend/autofilm-record.html"
    },
    {
      "src": "/dashboard",
      "dest": "/frontend/autofilm-dashboard.html"
    },
    {
      "src": "/onboard",
      "dest": "/frontend/autofilm-onboard.html"
    },
    {
      "src": "/inbox",
      "dest": "/frontend/autofilm-inbox.html"
    },
    {
      "src": "/workflows",
      "dest": "/frontend/autofilm-workflows.html"
    },
    {
      "src": "/reels",
      "dest": "/frontend/autofilm-reels.html"
    },
    {
      "src": "/group",
      "dest": "/frontend/autofilm-group.html"
    },
    {
      "src": "/mpi",
      "dest": "/frontend/autofilm-mpi.html"
    },
    {
      "src": "/call",
      "dest": "/frontend/autofilm-call.html"
    },
    {
      "src": "/service",
      "dest": "/frontend/autofilm-service.html"
    },
    {
      "src": "/spin",
      "dest": "/frontend/autofilm-spin.html"
    },
    {
      "src": "/terms",
      "dest": "/frontend/terms.html"
    },
    {
      "src": "/privacy",
      "dest": "/frontend/privacy.html"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
